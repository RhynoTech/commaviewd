diff --git a/selfdrive/ui/commaview_export.py b/selfdrive/ui/commaview_export.py
new file mode 100644
index 0000000..ee2d421
--- /dev/null
+++ b/selfdrive/ui/commaview_export.py
@@ -0,0 +1,388 @@
+import json
+import math
+import os
+import socket
+import struct
+import time
+
+from cereal import custom
+from openpilot.common.transformations.camera import DEVICE_CAMERAS
+
+COMMAVIEW_RUNTIME_FLAVOR = "SUNNYPILOT"
+COMMAVIEW_RUNTIME_FLAVOR_UNKNOWN = "UNKNOWN"
+COMMAVIEW_FRAME_VERSION = 1
+COMMAVIEW_CONTROL_SERVICE_INDEX = 0
+COMMAVIEW_SCENE_SERVICE_INDEX = 1
+COMMAVIEW_STATUS_SERVICE_INDEX = 2
+COMMAVIEW_SOCKET_PATH_DEFAULT = "/data/commaview/run/ui-export.sock"
+COMMAVIEW_CONNECT_RETRY_SEC = 1.0
+COMMAVIEW_SOCKET_TIMEOUT_SEC = 0.05
+
+
+def _safe_float(value) -> float:
+  try:
+    result = float(value)
+  except (TypeError, ValueError):
+    return 0.0
+  return result if math.isfinite(result) else 0.0
+
+
+def _safe_int(value) -> int:
+  try:
+    if hasattr(value, "raw"):
+      value = value.raw
+    return int(value)
+  except (TypeError, ValueError):
+    return 0
+
+
+def _float_list(values) -> list[float]:
+  return [_safe_float(v) for v in values]
+
+
+def _path_dict(source) -> dict:
+  return {
+    "x": _float_list(getattr(source, "x", [])),
+    "y": _float_list(getattr(source, "y", [])),
+    "z": _float_list(getattr(source, "z", [])),
+  }
+
+
+def _lead_dict(source) -> dict:
+  return {
+    "dRel": _safe_float(getattr(source, "dRel", 0.0)),
+    "yRel": _safe_float(getattr(source, "yRel", 0.0)),
+    "vRel": _safe_float(getattr(source, "vRel", 0.0)),
+    "aRel": _safe_float(getattr(source, "aRel", 0.0)),
+    "status": bool(getattr(source, "status", False)),
+  }
+
+
+def _commaview_camera_offset(params) -> float:
+  try:
+    return _safe_float(params.get("CameraOffset", return_default=True) or 0.0)
+  except (TypeError, ValueError):
+    return 0.0
+
+
+def _status_mode_name(status) -> str:
+  status_value = str(status.value if hasattr(status, "value") else status)
+  return {
+    "disengaged": "disengaged",
+    "engaged": "engaged",
+    "override": "override",
+    "lat_only": "latOnly",
+    "long_only": "longOnly",
+  }.get(status_value, "unknown")
+
+
+class _CommaViewSocketExporter:
+  def __init__(self, flavor: str):
+    self._flavor = flavor if flavor in ("OPENPILOT", "SUNNYPILOT") else COMMAVIEW_RUNTIME_FLAVOR_UNKNOWN
+    self._socket_path = os.environ.get("COMMAVIEWD_UI_EXPORT_SOCKET") or COMMAVIEW_SOCKET_PATH_DEFAULT
+    self._sock = None
+    self._next_connect_attempt = 0.0
+    self._active_camera = "road"
+
+  def publish(self, ui_state) -> None:
+    try:
+      self._send_json(COMMAVIEW_CONTROL_SERVICE_INDEX, self._control_payload(ui_state))
+      self._send_json(COMMAVIEW_SCENE_SERVICE_INDEX, self._scene_payload(ui_state))
+      self._send_json(COMMAVIEW_STATUS_SERVICE_INDEX, self._status_payload(ui_state))
+    except OSError:
+      self._close()
+
+  def _connect(self) -> bool:
+    if self._sock is not None:
+      return True
+    now = time.monotonic()
+    if now < self._next_connect_attempt:
+      return False
+    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
+    sock.settimeout(COMMAVIEW_SOCKET_TIMEOUT_SEC)
+    try:
+      sock.connect(self._socket_path)
+    except OSError:
+      sock.close()
+      self._next_connect_attempt = now + COMMAVIEW_CONNECT_RETRY_SEC
+      return False
+    self._sock = sock
+    self._next_connect_attempt = 0.0
+    return True
+
+  def _close(self) -> None:
+    if self._sock is not None:
+      try:
+        self._sock.close()
+      except OSError:
+        pass
+    self._sock = None
+
+  def _send_json(self, service_index: int, payload: dict) -> None:
+    if not self._connect():
+      return
+    raw = json.dumps(payload, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
+    frame = bytes((COMMAVIEW_FRAME_VERSION, service_index)) + raw
+    packet = struct.pack(">I", len(frame)) + frame
+    try:
+      self._sock.sendall(packet)
+    except OSError:
+      self._close()
+      raise
+
+  def _service_log_mono(self, ui_state, *services: str) -> int:
+    values = []
+    for service in services:
+      try:
+        values.append(int(ui_state.sm.logMonoTime.get(service, 0) or 0))
+      except (AttributeError, TypeError, ValueError):
+        values.append(0)
+    return max(values) if values else 0
+
+  def _resolve_camera(self, ui_state):
+    default_device_camera = DEVICE_CAMERAS[("tici", "ar0231")]
+    device_camera = default_device_camera
+    have_real_camera_key = ui_state.sm.seen["roadCameraState"] and ui_state.sm.seen["deviceState"]
+    if have_real_camera_key:
+      camera_key = (str(ui_state.sm["deviceState"].deviceType), str(ui_state.sm["roadCameraState"].sensor))
+      device_camera = DEVICE_CAMERAS.get(camera_key, default_device_camera)
+
+    wide_camera_ready = (
+      ui_state.sm.seen["wideRoadCameraState"] and
+      ui_state.sm.alive["wideRoadCameraState"] and
+      ui_state.sm.valid["wideRoadCameraState"]
+    )
+    experimental_mode = bool(ui_state.sm["selfdriveState"].experimentalMode)
+    if not experimental_mode or not wide_camera_ready:
+      self._active_camera = "road"
+    else:
+      v_ego = _safe_float(ui_state.sm["carState"].vEgo)
+      if v_ego < 5.0:
+        self._active_camera = "wideRoad"
+      elif v_ego > 10.0:
+        self._active_camera = "road"
+
+    return self._active_camera, device_camera
+
+  def _speed_limit_pre_active_icon(self, ui_state) -> str:
+    if ui_state.sm.recv_frame["longitudinalPlanSP"] < ui_state.started_frame:
+      return "none"
+    speed_limit = _safe_float(ui_state.sm["longitudinalPlanSP"].speedLimit.resolver.speedLimitFinalLast)
+    if speed_limit <= 0.0:
+      return "none"
+    car_state = ui_state.sm["carState"]
+    controls_state = ui_state.sm["controlsState"]
+    v_cruise_cluster = _safe_float(getattr(car_state, "vCruiseCluster", 0.0))
+    set_speed = _safe_float(controls_state.vCruiseDEPRECATED if v_cruise_cluster == 0.0 else v_cruise_cluster)
+    speed_conv = 3.6 if ui_state.is_metric else 2.2369362920544
+    if not ui_state.is_metric:
+      set_speed *= 0.621371
+    speed_limit_display = speed_limit * speed_conv
+    set_speed_round = round(set_speed)
+    speed_limit_round = round(speed_limit_display)
+    if set_speed_round < speed_limit_round:
+      return "up"
+    if set_speed_round > speed_limit_round:
+      return "down"
+    return "none"
+
+  def _control_payload(self, ui_state) -> dict:
+    payload = {
+      "exportVersion": 4,
+      "speedMps": 0.0,
+      "speedClusterMps": 0.0,
+      "cruiseSetSpeedMps": 0.0,
+      "standstill": False,
+      "steeringAngleDeg": 0.0,
+      "steeringPressed": False,
+      "engaged": bool(ui_state.engaged),
+      "isMetric": bool(ui_state.is_metric),
+      "started": bool(ui_state.started),
+      "leftBlinker": False,
+      "rightBlinker": False,
+      "leftBlindspot": False,
+      "rightBlindspot": False,
+      "latActive": False,
+      "longActive": False,
+      "logMonoTime": self._service_log_mono(ui_state, "carState", "carControl", "controlsState"),
+    }
+    if ui_state.sm.recv_frame["carState"] >= ui_state.started_frame:
+      car_state = ui_state.sm["carState"]
+      controls_state = ui_state.sm["controlsState"]
+      v_cruise_cluster = _safe_float(getattr(car_state, "vCruiseCluster", 0.0))
+      payload.update({
+        "speedMps": _safe_float(car_state.vEgo),
+        "speedClusterMps": _safe_float(car_state.vEgoCluster),
+        "cruiseSetSpeedMps": _safe_float(controls_state.vCruiseDEPRECATED if v_cruise_cluster == 0.0 else v_cruise_cluster),
+        "standstill": bool(car_state.standstill),
+        "steeringAngleDeg": _safe_float(car_state.steeringAngleDeg),
+        "steeringPressed": bool(car_state.steeringPressed),
+        "leftBlinker": bool(car_state.leftBlinker),
+        "rightBlinker": bool(car_state.rightBlinker),
+        "leftBlindspot": bool(car_state.leftBlindspot),
+        "rightBlindspot": bool(car_state.rightBlindspot),
+      })
+    if ui_state.sm.recv_frame["carControl"] >= ui_state.started_frame:
+      car_control = ui_state.sm["carControl"]
+      payload["latActive"] = bool(car_control.latActive)
+      payload["longActive"] = bool(car_control.longActive)
+    return payload
+
+  def _scene_payload(self, ui_state) -> dict:
+    active_camera, device_camera = self._resolve_camera(ui_state)
+    calibration = {
+      "rpyCalib": [],
+      "height": [],
+      "calStatus": 0,
+      "calPerc": 0,
+      "cameraIntrinsics": [],
+      "cameraOffset": [0.0, _commaview_camera_offset(ui_state.params), 0.0],
+      "cameraRpyOffset": [0.0, 0.0, 0.0],
+    }
+    if device_camera is not None:
+      intrinsics = device_camera.ecam.intrinsics if active_camera == "wideRoad" else device_camera.fcam.intrinsics
+      calibration["cameraIntrinsics"] = [
+        _safe_float(intrinsics[0, 0]),
+        _safe_float(intrinsics[1, 1]),
+        _safe_float(intrinsics[0, 2]),
+        _safe_float(intrinsics[1, 2]),
+      ]
+
+    payload = {
+      "exportVersion": 3,
+      "frameId": 0,
+      "frameIdExtra": 0,
+      "frameAge": 0,
+      "frameDropPerc": 0.0,
+      "timestampEof": 0,
+      "laneLines": [],
+      "roadEdges": [],
+      "position": {"x": [], "y": [], "z": []},
+      "leadOne": _lead_dict(None),
+      "leadTwo": _lead_dict(None),
+      "calibration": calibration,
+      "activeCamera": active_camera,
+      "logMonoTime": self._service_log_mono(ui_state, "modelV2", "radarState", "liveCalibration"),
+    }
+    if ui_state.sm.recv_frame["modelV2"] >= ui_state.started_frame:
+      model = ui_state.sm["modelV2"]
+      radar_state = ui_state.sm["radarState"]
+      live_calibration = ui_state.sm["liveCalibration"]
+      payload.update({
+        "frameId": _safe_int(model.frameId),
+        "frameIdExtra": _safe_int(model.frameIdExtra),
+        "frameAge": _safe_int(model.frameAge),
+        "frameDropPerc": _safe_float(model.frameDropPerc),
+        "timestampEof": _safe_int(model.timestampEof),
+        "laneLines": [
+          {
+            "points": _path_dict(model_lane_line),
+            "prob": _safe_float(model.laneLineProbs[idx] if idx < len(model.laneLineProbs) else 0.0),
+            "std": _safe_float(model.laneLineStds[idx] if idx < len(model.laneLineStds) else 0.0),
+          }
+          for idx, model_lane_line in enumerate(model.laneLines)
+        ],
+        "roadEdges": [
+          {
+            "points": _path_dict(model_road_edge),
+            "std": _safe_float(model.roadEdgeStds[idx] if idx < len(model.roadEdgeStds) else 0.0),
+          }
+          for idx, model_road_edge in enumerate(model.roadEdges)
+        ],
+        "position": _path_dict(model.position),
+        "leadOne": _lead_dict(radar_state.leadOne),
+        "leadTwo": _lead_dict(radar_state.leadTwo),
+      })
+      calibration.update({
+        "rpyCalib": _float_list(live_calibration.rpyCalib),
+        "height": _float_list(live_calibration.height),
+        "calStatus": _safe_int(live_calibration.calStatus),
+        "calPerc": _safe_int(live_calibration.calPerc),
+      })
+      if active_camera == "wideRoad" and hasattr(live_calibration, "wideFromDeviceEuler") and len(live_calibration.wideFromDeviceEuler) == 3:
+        calibration["cameraRpyOffset"] = _float_list(live_calibration.wideFromDeviceEuler)
+    return payload
+
+  def _status_payload(self, ui_state) -> dict:
+    payload = {
+      "exportVersion": 6,
+      "enabled": False,
+      "active": False,
+      "engageable": False,
+      "alertText1": "",
+      "alertText2": "",
+      "alertType": "none",
+      "alertStatus": 0,
+      "alertSize": 0,
+      "driverMonitoring": {
+        "faceDetected": False,
+        "isDistracted": False,
+        "isRhd": False,
+        "poseYawOffset": 0.0,
+        "posePitchOffset": 0.0,
+        "poseYawValidCount": 0,
+        "posePitchValidCount": 0,
+        "isLowStd": False,
+        "driverMonitoringActive": False,
+      },
+      "experimentalMode": False,
+      "runtimeFlavor": self._flavor,
+      "statusMode": "disengaged" if not ui_state.started else "unknown",
+      "speedLimitPreActive": False,
+      "speedLimitPreActiveIcon": "none",
+      "blindspotIndicatorsEnabled": bool(ui_state.params.get_bool("BlindSpot")),
+      "rainbowPathEnabled": bool(ui_state.params.get_bool("RainbowMode")),
+      "logMonoTime": self._service_log_mono(ui_state, "selfdriveState", "driverMonitoringState", "longitudinalPlanSP"),
+    }
+    if ui_state.sm.recv_frame["selfdriveState"] >= ui_state.started_frame:
+      selfdrive_state = ui_state.sm["selfdriveState"]
+      driver_monitoring = ui_state.sm["driverMonitoringState"]
+      payload.update({
+        "enabled": bool(selfdrive_state.enabled),
+        "active": bool(selfdrive_state.active),
+        "engageable": bool(selfdrive_state.engageable),
+        "alertText1": str(selfdrive_state.alertText1),
+        "alertText2": str(selfdrive_state.alertText2),
+        "alertType": str(selfdrive_state.alertType),
+        "alertStatus": _safe_int(selfdrive_state.alertStatus),
+        "alertSize": _safe_int(selfdrive_state.alertSize),
+        "experimentalMode": bool(selfdrive_state.experimentalMode),
+        "statusMode": _status_mode_name(ui_state.status),
+        "driverMonitoring": {
+          "faceDetected": bool(driver_monitoring.faceDetected),
+          "isDistracted": bool(driver_monitoring.isDistracted),
+          "isRhd": bool(driver_monitoring.isRHD),
+          "poseYawOffset": _safe_float(driver_monitoring.poseYawOffset),
+          "posePitchOffset": _safe_float(driver_monitoring.posePitchOffset),
+          "poseYawValidCount": _safe_int(driver_monitoring.poseYawValidCount),
+          "posePitchValidCount": _safe_int(driver_monitoring.posePitchValidCount),
+          "isLowStd": bool(driver_monitoring.isLowStd),
+          "driverMonitoringActive": bool(driver_monitoring.isActiveMode),
+        },
+      })
+      if ui_state.sm.recv_frame["longitudinalPlanSP"] >= ui_state.started_frame:
+        speed_limit_assist = ui_state.sm["longitudinalPlanSP"].speedLimit.assist
+        payload["speedLimitPreActive"] = speed_limit_assist.state == custom.LongitudinalPlanSP.SpeedLimit.AssistState.preActive
+        if payload["speedLimitPreActive"]:
+          payload["speedLimitPreActiveIcon"] = self._speed_limit_pre_active_icon(ui_state)
+    return payload
