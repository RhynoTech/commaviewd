+  def _onroad_events_payload(self, ui_state) -> dict:
+    payload = {
+      "exportVersion": 1,
+      "events": [],
+      "logMonoTime": self._service_log_mono(ui_state, "onroadEvents"),
+    }
+    if ui_state.sm.recv_frame["onroadEvents"] >= ui_state.started_frame:
