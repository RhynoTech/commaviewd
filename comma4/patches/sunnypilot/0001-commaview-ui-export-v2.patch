+        "alertSize": _safe_int(selfdrive_state.alertSize),
+        "alertHudVisual": _safe_int(getattr(selfdrive_state, "alertHudVisual", 0)),
+        "experimentalMode": bool(selfdrive_state.experimentalMode),
