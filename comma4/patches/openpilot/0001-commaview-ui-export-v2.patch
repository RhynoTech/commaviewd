@@ -170,6 +183,171 @@ class UIState:
 
       self._started_prev = self.started
 
+  @staticmethod
+  def _copy_commaview_path(target, source) -> None:
+    target.x = [float(v) for v in source.x]
+    target.y = [float(v) for v in source.y]
+    target.z = [float(v) for v in source.z]
+
+  @staticmethod
+  def _copy_commaview_lead(target, source) -> None:
+    target.dRel = float(source.dRel)
+    target.yRel = float(source.yRel)
+    target.vRel = float(source.vRel)
+    target.aRel = float(source.aRel)
+    target.status = bool(source.status)
+
+  def _commaview_camera_offset(self) -> float:
+    try:
+      return float(self.params.get("CameraOffset", return_default=True) or 0.0)
+    except (TypeError, ValueError):
+      return 0.0
+
+  def _resolve_commaview_camera(self):
+    default_device_camera = DEVICE_CAMERAS[("tici", "ar0231")]
+    device_camera = default_device_camera
+    have_real_camera_key = self.sm.seen["roadCameraState"] and self.sm.seen["deviceState"]
+    if have_real_camera_key:
+      camera_key = (str(self.sm["deviceState"].deviceType), str(self.sm["roadCameraState"].sensor))
+      device_camera = DEVICE_CAMERAS.get(camera_key)
+
+    wide_camera_ready = (
+      self.sm.seen["wideRoadCameraState"] and
+      self.sm.alive["wideRoadCameraState"] and
+      self.sm.valid["wideRoadCameraState"]
+    )
+    experimental_mode = bool(self.sm["selfdriveState"].experimentalMode)
+    if not experimental_mode or not wide_camera_ready:
+      self._commaview_active_camera = "road"
+    else:
+      v_ego = float(self.sm["carState"].vEgo)
+      if v_ego < 5.0:
+        self._commaview_active_camera = "wideRoad"
+      elif v_ego > 10.0:
+        self._commaview_active_camera = "road"
+
+    return self._commaview_active_camera, device_camera
+
+  @staticmethod
+  def _commaview_status_mode_name(status) -> str:
+    status_value = str(status.value if hasattr(status, "value") else status)
+    return {
+      "disengaged": "disengaged",
+      "engaged": "engaged",
+      "override": "override",
+      "lat_only": "latOnly",
+      "long_only": "longOnly",
+    }.get(status_value, "unknown")
+
+  def _publish_commaview_control(self) -> None:
+    # COMMAVIEW UI EXPORT V4
+    msg = messaging.new_message("commaViewControl")
+    control = msg.commaViewControl
+    control.exportVersion = 4
+    control.started = bool(self.started)
+    control.isMetric = bool(self.is_metric)
+    control.engaged = bool(self.engaged)
+    if self.sm.recv_frame["carState"] >= self.started_frame:
+      car_state = self.sm["carState"]
+      controls_state = self.sm["controlsState"]
+      v_cruise_cluster = car_state.vCruiseCluster
+      control.speedMps = float(car_state.vEgo)
+      control.speedClusterMps = float(car_state.vEgoCluster)
+      control.cruiseSetSpeed = float(controls_state.vCruiseDEPRECATED if v_cruise_cluster == 0.0 else v_cruise_cluster)
+      control.standstill = bool(car_state.standstill)
+      control.steeringAngleDeg = float(car_state.steeringAngleDeg)
+      control.steeringPressed = bool(car_state.steeringPressed)
+      control.leftBlinker = bool(car_state.leftBlinker)
+      control.rightBlinker = bool(car_state.rightBlinker)
+      control.leftBlindspot = bool(car_state.leftBlindspot)
+      control.rightBlindspot = bool(car_state.rightBlindspot)
+    if self.sm.recv_frame["carControl"] >= self.started_frame:
+      car_control = self.sm["carControl"]
+      control.latActive = bool(car_control.latActive)
+      control.longActive = bool(car_control.longActive)
+    self._commaview_pm.send("commaViewControl", msg)
+
+  def _publish_commaview_scene(self) -> None:
+    msg = messaging.new_message("commaViewScene")
+    scene = msg.commaViewScene
+    scene.exportVersion = 2
+    active_camera, device_camera = self._resolve_commaview_camera()
+    scene.activeCamera = active_camera
+    if device_camera is not None:
+      intrinsics = device_camera.ecam.intrinsics if active_camera == "wideRoad" else device_camera.fcam.intrinsics
+      scene.calibration.cameraIntrinsics = [
+        float(intrinsics[0, 0]),
+        float(intrinsics[1, 1]),
+        float(intrinsics[0, 2]),
+        float(intrinsics[1, 2]),
+      ]
+    scene.calibration.cameraOffset = [0.0, float(self._commaview_camera_offset()), 0.0]
+    scene.calibration.cameraRpyOffset = [0.0, 0.0, 0.0]
+    if self.sm.recv_frame["modelV2"] >= self.started_frame:
+      model = self.sm["modelV2"]
+      radar_state = self.sm["radarState"]
+      live_calibration = self.sm["liveCalibration"]
+      scene.frameId = int(model.frameId)
+      scene.frameIdExtra = int(model.frameIdExtra)
+      scene.frameAge = int(model.frameAge)
+      scene.frameDropPerc = float(model.frameDropPerc)
+      scene.timestampEof = int(model.timestampEof)
+      scene.init('laneLines', len(model.laneLines))
+      for idx, model_lane_line in enumerate(model.laneLines):
+        lane_line = scene.laneLines[idx]
+        self._copy_commaview_path(lane_line.points, model_lane_line)
+        lane_line.prob = float(model.laneLineProbs[idx] if idx < len(model.laneLineProbs) else 0.0)
+        lane_line.std = float(model.laneLineStds[idx] if idx < len(model.laneLineStds) else 0.0)
+      scene.init('roadEdges', len(model.roadEdges))
+      for idx, model_road_edge in enumerate(model.roadEdges):
+        road_edge = scene.roadEdges[idx]
+        self._copy_commaview_path(road_edge.points, model_road_edge)
+        road_edge.std = float(model.roadEdgeStds[idx] if idx < len(model.roadEdgeStds) else 0.0)
+      self._copy_commaview_path(scene.position, model.position)
+      self._copy_commaview_lead(scene.leadOne, radar_state.leadOne)
+      self._copy_commaview_lead(scene.leadTwo, radar_state.leadTwo)
+      scene.calibration.rpyCalib = [float(v) for v in live_calibration.rpyCalib]
+      scene.calibration.height = [float(v) for v in live_calibration.height]
+      if active_camera == "wideRoad" and hasattr(live_calibration, "wideFromDeviceEuler") and len(live_calibration.wideFromDeviceEuler) == 3:
+        scene.calibration.cameraRpyOffset = [float(v) for v in live_calibration.wideFromDeviceEuler]
+      cal_status = live_calibration.calStatus
+      scene.calibration.calStatus = int(cal_status.raw if hasattr(cal_status, "raw") else cal_status)
+      scene.calibration.calPerc = int(live_calibration.calPerc)
+    self._commaview_pm.send("commaViewScene", msg)
+
+  def _publish_commaview_status(self) -> None:
+    msg = messaging.new_message("commaViewStatus")
+    status = msg.commaViewStatus
+    status.exportVersion = 6
+    status.experimentalMode = False
+    status.runtimeFlavor = COMMAVIEW_RUNTIME_FLAVOR if COMMAVIEW_RUNTIME_FLAVOR in ("OPENPILOT", "SUNNYPILOT") else COMMAVIEW_RUNTIME_FLAVOR_UNKNOWN
+    status.statusMode = "disengaged" if not self.started else "unknown"
+    status.speedLimitPreActive = False
+    status.speedLimitPreActiveIcon = "none"
+    status.blindspotIndicatorsEnabled = bool(self.params.get_bool("BlindSpot"))
+    status.rainbowPathEnabled = bool(self.params.get_bool("RainbowMode"))
+    if self.sm.recv_frame["selfdriveState"] >= self.started_frame:
+      selfdrive_state = self.sm["selfdriveState"]
+      driver_monitoring = self.sm["driverMonitoringState"]
+      status.enabled = bool(selfdrive_state.enabled)
+      status.active = bool(selfdrive_state.active)
+      status.engageable = bool(selfdrive_state.engageable)
+      status.alertText1 = str(selfdrive_state.alertText1)
+      status.alertText2 = str(selfdrive_state.alertText2)
+      status.alertType = str(selfdrive_state.alertType)
+      alert_status = selfdrive_state.alertStatus
+      alert_size = selfdrive_state.alertSize
+      status.alertStatus = int(alert_status.raw if hasattr(alert_status, "raw") else alert_status)
+      status.alertSize = int(alert_size.raw if hasattr(alert_size, "raw") else alert_size)
+      status.faceDetected = bool(driver_monitoring.faceDetected)
+      status.isDistracted = bool(driver_monitoring.isDistracted)
+      status.isRhd = bool(driver_monitoring.isRHD)
+      status.poseYawOffset = float(driver_monitoring.poseYawOffset)
+      status.posePitchOffset = float(driver_monitoring.posePitchOffset)
+      status.poseYawValidCount = int(driver_monitoring.poseYawValidCount)
+      status.posePitchValidCount = int(driver_monitoring.posePitchValidCount)
+      status.isLowStd = bool(driver_monitoring.isLowStd)
+      status.driverMonitoringActive = bool(driver_monitoring.isActiveMode)
+      status.experimentalMode = bool(selfdrive_state.experimentalMode)
+      status.statusMode = self._commaview_status_mode_name(self.status)
+    self._commaview_pm.send("commaViewStatus", msg)
+
   def update_params(self) -> None:
