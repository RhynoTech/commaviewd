index 0000000..f4623ad
--- /dev/null
+++ b/cereal/commaview.capnp
@@ -0,0 +1,119 @@
+using Cxx = import "./include/c++.capnp";
+$Cxx.namespace("cereal");
+
+@0xe3d2f2c0b57c9f11;
+
+struct CommaViewControl {
+  exportVersion @0 :UInt16;
+  speedMps @1 :Float32;
+  speedClusterMps @2 :Float32;
+  cruiseSetSpeed @3 :Float32;
+  standstill @4 :Bool;
+  steeringAngleDeg @5 :Float32;
+  steeringPressed @6 :Bool;
+  engaged @7 :Bool;
+  isMetric @8 :Bool;
+  started @9 :Bool;
+  leftBlinker @10 :Bool;
+  rightBlinker @11 :Bool;
+  leftBlindspot @12 :Bool;
+  rightBlindspot @13 :Bool;
+  latActive @14 :Bool;
+  longActive @15 :Bool;
+}
+
+struct CommaViewLead {
+  dRel @0 :Float32;
+  yRel @1 :Float32;
+  vRel @2 :Float32;
+  aRel @3 :Float32;
+  status @4 :Bool;
+}
+
+struct CommaViewPath3f {
+  x @0 :List(Float32);
+  y @1 :List(Float32);
+  z @2 :List(Float32);
+}
+
+struct CommaViewLaneLine {
+  points @0 :CommaViewPath3f;
+  prob @1 :Float32;
+  std @2 :Float32;
+}
+
+struct CommaViewRoadEdge {
+  points @0 :CommaViewPath3f;
+  std @1 :Float32;
+}
+
+enum CommaViewCameraSource {
+  road @0;
+  wideRoad @1;
+}
+
+enum CommaViewStatusMode {
+  unknown @0;
+  disengaged @1;
+  engaged @2;
+  override @3;
+  latOnly @4;
+  longOnly @5;
+}
+
+enum CommaViewSpeedLimitPreActiveIcon {
+  none @0;
+  up @1;
+  down @2;
+}
+
+struct CommaViewCalibration {
+  rpyCalib @0 :List(Float32);
+  height @1 :List(Float32);
+  calStatus @2 :UInt16;
+  calPerc @3 :UInt16;
+  cameraIntrinsics @4 :List(Float32);
+  cameraOffset @5 :List(Float32);
+  cameraRpyOffset @6 :List(Float32);
+}
+
+struct CommaViewScene {
+  exportVersion @0 :UInt16;
+  frameId @1 :UInt32;
+  frameIdExtra @2 :UInt32;
+  frameAge @3 :UInt32;
+  frameDropPerc @4 :Float32;
+  timestampEof @5 :UInt64;
+  laneLines @6 :List(CommaViewLaneLine);
+  roadEdges @7 :List(CommaViewRoadEdge);
+  position @8 :CommaViewPath3f;
+  leadOne @9 :CommaViewLead;
+  leadTwo @10 :CommaViewLead;
+  calibration @11 :CommaViewCalibration;
+  activeCamera @12 :CommaViewCameraSource;
+}
+
+struct CommaViewStatus {
+  exportVersion @0 :UInt16;
+  enabled @1 :Bool;
+  active @2 :Bool;
+  engageable @3 :Bool;
+  alertText1 @4 :Text;
+  alertText2 @5 :Text;
+  alertType @6 :Text;
+  alertStatus @7 :UInt16;
+  alertSize @8 :UInt16;
+  faceDetected @9 :Bool;
+  isDistracted @10 :Bool;
+  isRhd @11 :Bool;
+  poseYawOffset @12 :Float32;
+  posePitchOffset @13 :Float32;
+  poseYawValidCount @14 :UInt16;
+  posePitchValidCount @15 :UInt16;
+  isLowStd @16 :Bool;
+  driverMonitoringActive @17 :Bool;
+  experimentalMode @18 :Bool;
+  runtimeFlavor @19 :Text;
+  statusMode @20 :CommaViewStatusMode;
+  speedLimitPreActive @21 :Bool;
+  speedLimitPreActiveIcon @22 :CommaViewSpeedLimitPreActiveIcon;
+  blindspotIndicatorsEnabled @23 :Bool;
+  rainbowPathEnabled @24 :Bool;
+}
